---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page Not Found">
  <!-- 404: Minimal error section (AD-6) -->
  <section class="error-page" aria-labelledby="error-heading">
    <div class="error-page__inner">
      <p class="error-page__code" aria-hidden="true">404</p>
      <h1 id="error-heading" class="error-page__heading">Page not found</h1>
      <p class="error-page__desc">
        Sorry, the page you're looking for doesn't exist or has been moved.
      </p>
      <a href="/" class="error-page__link">Go home</a>
    </div>
  </section>
</Layout>

<style>
  .error-page {
    padding: 8rem 1.5rem;
    text-align: center;
    background: var(--bg);
  }

  .error-page__inner {
    max-width: 36rem;
    margin: 0 auto;
  }

  .error-page__code {
    font-size: 6rem;
    font-weight: 800;
    color: var(--primary);
    line-height: 1;
    margin: 0 0 1rem;
    font-family: 'Nunito', system-ui, sans-serif;
  }

  .error-page__heading {
    font-size: calc(clamp(1.5rem, 3vw, 2.25rem) * var(--heading-scale));
    font-weight: 800;
    color: var(--text);
    margin: 0 0 1rem;
  }

  .error-page__desc {
    color: var(--text-muted);
    font-size: 1.125rem;
    margin: 0 0 2.5rem;
  }

  .error-page__link {
    background: var(--accent);
    color: #1C1A18;
    padding: 0.9375rem 2.25rem;
    border-radius: 999px;
    font-weight: 700;
    display: inline-block;
    font-family: 'Nunito', system-ui, sans-serif;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  @media (hover: hover) {
    .error-page__link:hover {
      transform: translateY(-3px) scale(1.05);
      text-decoration: none;
    }
  }
</style>

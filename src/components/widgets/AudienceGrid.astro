---
interface Props {
  items: { title: string; description: string }[];
}

const { items } = Astro.props;
---

<section style="padding: 5rem 1.5rem; background: var(--bg-alt);" aria-labelledby="audience-heading">
  <div style="max-width: 72rem; margin: 0 auto;">
    <h2
      id="audience-heading"
      style="text-align: center; font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 700; color: var(--text); margin: 0 0 3rem;"
    >
      Built for businesses like yours
    </h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem;">
      {items.map((item) => (
        <article
          style="background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 2rem; box-shadow: var(--shadow);"
        >
          <h3 style="font-size: 1.125rem; font-weight: 700; color: var(--text); margin: 0 0 0.75rem;">
            {item.title}
          </h3>
          <p style="color: var(--text-muted); margin: 0; line-height: 1.7;">
            {item.description}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>

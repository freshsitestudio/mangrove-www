---
interface Props {
  steps: { number: number; title: string; description: string }[];
}

const { steps } = Astro.props;
---

<section style="padding: 5rem 1.5rem; background: var(--bg-alt);" aria-labelledby="process-heading">
  <div style="max-width: 56rem; margin: 0 auto;">
    <h2
      id="process-heading"
      style="text-align: center; font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 700; color: var(--text); margin: 0 0 3rem;"
    >
      How it works
    </h2>
    <ol style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 2rem;">
      {steps.map((step) => (
        <li style="display: flex; gap: 1.5rem; align-items: flex-start;">
          <span
            aria-hidden="true"
            style="flex-shrink: 0; width: 3rem; height: 3rem; border-radius: 50%; background: var(--primary); color: #fff; font-weight: 600; font-size: 1.125rem; display: flex; align-items: center; justify-content: center;"
          >
            {step.number}
          </span>
          <div>
            <h3 style="font-size: 1.125rem; font-weight: 700; color: var(--text); margin: 0 0 0.5rem;">
              {step.title}
            </h3>
            <p style="color: var(--text-muted); margin: 0; line-height: 1.7;">
              {step.description}
            </p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

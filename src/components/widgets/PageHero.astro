---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<section
  style="background: var(--bg-alt); border-bottom: 1px solid var(--border); padding: 4rem 1.5rem 3rem;"
  aria-labelledby="pagehero-heading"
>
  <div style="max-width: 56rem; margin: 0 auto; text-align: center;">
    <h1
      id="pagehero-heading"
      style="font-size: clamp(1.75rem, 4vw, 3rem); font-weight: 700; color: var(--text); margin: 0 0 1rem;"
    >
      {title}
    </h1>
    {subtitle && (
      <p style="font-size: 1.125rem; color: var(--text-muted); max-width: 40rem; margin: 0 auto;">
        {subtitle}
      </p>
    )}
  </div>
</section>

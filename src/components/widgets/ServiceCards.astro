---
interface Props {
  services: {
    name: string;
    tagline: string;
    price?: string;
    features: string[];
  }[];
}

const { services } = Astro.props;
---

<section style="padding: 5rem 1.5rem; background: var(--bg);" aria-labelledby="services-heading">
  <div style="max-width: 72rem; margin: 0 auto;">
    <h2
      id="services-heading"
      style="text-align: center; font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 700; color: var(--text); margin: 0 0 3rem;"
    >
      Our services
    </h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem;">
      {services.map((service) => (
        <article
          style="background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 2.5rem; box-shadow: var(--shadow); display: flex; flex-direction: column;"
        >
          <h3 style="font-size: 1.25rem; font-weight: 700; color: var(--text); margin: 0 0 0.5rem;">
            {service.name}
          </h3>
          <p style="color: var(--text-muted); font-size: 0.9375rem; margin: 0 0 1.25rem; flex: 1;">
            {service.tagline}
          </p>
          {service.price && (
            <p style="font-size: 1.5rem; font-weight: 600; color: var(--primary); margin: 0 0 1.25rem;">
              {service.price}
            </p>
          )}
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem;">
            {service.features.map((f) => (
              <li style="display: flex; align-items: flex-start; gap: 0.5rem; color: var(--text-muted); font-size: 0.9375rem;">
                <span style="color: var(--primary); flex-shrink: 0; margin-top: 0.1em;" aria-hidden="true">✓</span>
                {f}
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

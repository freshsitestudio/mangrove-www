---
// Widget variant contract (Epic 6 / FR-20): handbook §8, DESIGN.md → §Widget variant glossary.
// Allowed IDs are glossary-verbatim, case-sensitive. Invalid/omitted → theme default.
type HeroVariant = "centeredGradient" | "fullBleedPhoto" | "splitProof" | "editorialLeft";

interface Props {
  tagline?: string;
  title: string;
  subtitle?: string;
  ctaPrimary?: { text: string; href: string };
  ctaSecondary?: { text: string; href: string };
  /** Glossary ID from DESIGN.md — e.g. "fullBleedPhoto" */
  variant?: HeroVariant;
}

const ALLOWED_VARIANTS: HeroVariant[] = ["centeredGradient", "fullBleedPhoto", "splitProof", "editorialLeft"];
const THEME_DEFAULT: HeroVariant = "fullBleedPhoto"; // DESIGN.md §Default variant per theme — warm-local

const {
  tagline,
  title,
  subtitle,
  ctaPrimary,
  ctaSecondary,
  variant: variantProp,
} = Astro.props;

const variant: HeroVariant = ALLOWED_VARIANTS.includes(variantProp as HeroVariant)
  ? (variantProp as HeroVariant)
  : THEME_DEFAULT;

// Layout DNA: fullBleedPhoto — soft warm background photo with a warm gradient scrim so
// centered copy stays readable; rounded CTA, warm copy sits below the headline.
const heroImage =
  "https://images.unsplash.com/photo-1521017432531-fbd92d768814?auto=format&fit=crop&w=1600&q=80";

// splitProof internal proof panel — representative stats, not a data-driven component
// (mirrors coastal-calm's own splitProof pattern; no new prop per FR-20 contract).
const proofStats = [
  { value: "4.8★", label: "Average customer rating" },
  { value: "9", label: "Years serving the neighbourhood" },
  { value: "100%", label: "Locally owned & run" },
];
---

{variant === "fullBleedPhoto" && (
  <section
    class="hero-photo"
    style={`background-image: linear-gradient(180deg, rgba(67, 20, 7, 0.15), rgba(67, 20, 7, 0.65)), url(${heroImage});`}
    aria-labelledby="hero-heading"
  >
    <div class="hero-photo__inner">
      {tagline && <p class="hero-photo__tagline">{tagline}</p>}
      <h1 id="hero-heading" class="hero-photo__title">{title}</h1>
      {subtitle && <p class="hero-photo__subtitle">{subtitle}</p>}
      {(ctaPrimary || ctaSecondary) && (
        <div class="hero-photo__actions">
          {ctaPrimary && (
            <a href={ctaPrimary.href} class="hero-photo__btn hero-photo__btn--primary">
              {ctaPrimary.text}
            </a>
          )}
          {ctaSecondary && (
            <a href={ctaSecondary.href} class="hero-photo__btn hero-photo__btn--secondary">
              {ctaSecondary.text}
            </a>
          )}
        </div>
      )}
    </div>
  </section>
)}

{variant === "centeredGradient" && (
  /* centeredGradient: soft warm gradient background (--gradient-start → --gradient-end), centered copy */
  <section class="hero-gradient" aria-labelledby="hero-heading">
    <div class="hero-gradient__inner">
      {tagline && <p class="hero-gradient__tagline">{tagline}</p>}
      <h1 id="hero-heading" class="hero-gradient__title">{title}</h1>
      {subtitle && <p class="hero-gradient__subtitle">{subtitle}</p>}
      {(ctaPrimary || ctaSecondary) && (
        <div class="hero-gradient__actions">
          {ctaPrimary && (
            <a href={ctaPrimary.href} class="hero-gradient__btn hero-gradient__btn--primary">
              {ctaPrimary.text}
            </a>
          )}
          {ctaSecondary && (
            <a href={ctaSecondary.href} class="hero-gradient__btn hero-gradient__btn--secondary">
              {ctaSecondary.text}
            </a>
          )}
        </div>
      )}
    </div>
  </section>
)}

{variant === "splitProof" && (
  /* splitProof: 50/50 split — headline + CTA on one side, a proof/stat panel on the other */
  <section class="hero-split" aria-labelledby="hero-heading">
    <div class="hero-split__inner">
      <div class="hero-split__copy">
        {tagline && <p class="hero-split__tagline">{tagline}</p>}
        <h1 id="hero-heading" class="hero-split__title">{title}</h1>
        {subtitle && <p class="hero-split__subtitle">{subtitle}</p>}
        {(ctaPrimary || ctaSecondary) && (
          <div class="hero-split__actions">
            {ctaPrimary && (
              <a href={ctaPrimary.href} class="hero-split__btn hero-split__btn--primary">
                {ctaPrimary.text}
              </a>
            )}
            {ctaSecondary && (
              <a href={ctaSecondary.href} class="hero-split__btn hero-split__btn--secondary">
                {ctaSecondary.text}
              </a>
            )}
          </div>
        )}
      </div>
      <div class="hero-split__proof community-card" role="group" aria-label="Why neighbours choose us">
        <p class="hero-split__proof-heading">Why neighbours choose us</p>
        <div class="hero-split__stats">
          {proofStats.map((stat) => (
            <div class="hero-split__stat">
              <p class="hero-split__stat-value">{stat.value}</p>
              <p class="hero-split__stat-label">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
)}

{variant === "editorialLeft" && (
  /* editorialLeft: oversized left-aligned type, generous whitespace, minimal imagery */
  <section class="hero-editorial" aria-labelledby="hero-heading">
    <div class="hero-editorial__inner">
      {tagline && <p class="hero-editorial__tagline">{tagline}</p>}
      <h1 id="hero-heading" class="hero-editorial__title">{title}</h1>
      {subtitle && <p class="hero-editorial__subtitle">{subtitle}</p>}
      {(ctaPrimary || ctaSecondary) && (
        <div class="hero-editorial__actions">
          {ctaPrimary && (
            <a href={ctaPrimary.href} class="hero-editorial__btn hero-editorial__btn--primary">
              {ctaPrimary.text}
            </a>
          )}
          {ctaSecondary && (
            <a href={ctaSecondary.href} class="hero-editorial__btn hero-editorial__btn--secondary">
              {ctaSecondary.text}
            </a>
          )}
        </div>
      )}
    </div>
  </section>
)}

<style>
  /* ---------- fullBleedPhoto (theme default) ---------- */
  .hero-photo {
    min-height: var(--hero-min-height);
    display: flex;
    align-items: center;
    justify-content: center;
    background-size: cover;
    background-position: center;
    text-align: center;
  }

  .hero-photo__inner {
    max-width: 44rem;
    padding: 4rem 1.5rem;
  }

  .hero-photo__tagline {
    display: inline-flex;
    color: #FEF3C7;
    font-weight: 700;
    font-size: 0.9375rem;
    letter-spacing: 0.04em;
    margin: 0 0 1rem;
    font-family: 'Nunito', system-ui, sans-serif;
  }

  .hero-photo__title {
    font-size: calc(clamp(2.25rem, 5vw, 3.75rem) * var(--heading-scale));
    font-weight: 800;
    color: #fff;
    line-height: 1.12;
    margin: 0 0 1.25rem;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.25);
  }

  /* Warm copy below headline, per DNA */
  .hero-photo__subtitle {
    font-family: 'Lora', Georgia, serif;
    font-size: 1.1875rem;
    color: rgba(255, 247, 237, 0.92);
    max-width: 38rem;
    margin: 0 auto 2.25rem;
  }

  .hero-photo__actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-photo__btn {
    font-family: 'Nunito', system-ui, sans-serif;
    padding: 0.9375rem 2.25rem;
    border-radius: 999px;
    font-weight: 700;
    font-size: 1rem;
    display: inline-block;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
  }

  .hero-photo__btn--primary {
    background: var(--accent);
    color: #1C1A18;
    box-shadow: var(--shadow-lg);
  }

  .hero-photo__btn--secondary {
    background: rgba(255, 255, 255, 0.14);
    color: #fff;
    border: 2px solid rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(6px);
  }

  @media (hover: hover) {
    .hero-photo__btn:hover {
      transform: translateY(-3px) scale(1.05);
      text-decoration: none;
    }
  }

  /* ---------- centeredGradient ---------- */
  .hero-gradient {
    background: linear-gradient(to bottom right, var(--gradient-start), var(--gradient-end));
    min-height: var(--hero-min-height);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: calc(var(--nav-height) + 3rem) 1.5rem 4rem;
    text-align: center;
  }

  .hero-gradient__inner {
    max-width: 44rem;
    margin: 0 auto;
  }

  .hero-gradient__tagline {
    display: inline-flex;
    color: var(--primary);
    font-weight: 700;
    font-size: 0.9375rem;
    letter-spacing: 0.04em;
    margin: 0 0 1rem;
    font-family: 'Nunito', system-ui, sans-serif;
  }

  .hero-gradient__title {
    font-size: calc(clamp(2.25rem, 5vw, 3.5rem) * var(--heading-scale));
    font-weight: 800;
    color: var(--text);
    line-height: 1.15;
    margin: 0 0 1.25rem;
  }

  .hero-gradient__subtitle {
    font-family: 'Lora', Georgia, serif;
    font-size: 1.1875rem;
    color: var(--text-muted);
    max-width: 34rem;
    margin: 0 auto 2rem;
  }

  .hero-gradient__actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-gradient__btn {
    font-family: 'Nunito', system-ui, sans-serif;
    padding: 0.9375rem 2.25rem;
    border-radius: 999px;
    font-weight: 700;
    font-size: 1rem;
    display: inline-block;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
  }

  .hero-gradient__btn--primary {
    background: var(--accent);
    color: #1C1A18;
    box-shadow: var(--shadow-lg);
  }

  .hero-gradient__btn--secondary {
    background: var(--surface);
    color: var(--text);
    border: 2px solid var(--border);
  }

  @media (hover: hover) {
    .hero-gradient__btn:hover {
      transform: translateY(-3px) scale(1.05);
      text-decoration: none;
    }
  }

  /* ---------- splitProof ---------- */
  .hero-split {
    background: var(--bg);
    min-height: var(--hero-min-height);
    display: flex;
    align-items: center;
  }

  .hero-split__inner {
    max-width: var(--container-max);
    margin: 0 auto;
    width: 100%;
    padding: calc(var(--nav-height) + 2.5rem) 1.5rem 3rem;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .hero-split__tagline {
    display: inline-flex;
    color: var(--primary);
    font-weight: 700;
    font-size: 0.9375rem;
    letter-spacing: 0.04em;
    margin: 0 0 1rem;
    font-family: 'Nunito', system-ui, sans-serif;
  }

  .hero-split__title {
    font-size: calc(clamp(2rem, 4vw, 3.25rem) * var(--heading-scale));
    font-weight: 800;
    color: var(--text);
    line-height: 1.12;
    margin: 0 0 1.25rem;
  }

  .hero-split__subtitle {
    font-family: 'Lora', Georgia, serif;
    font-size: 1.0625rem;
    color: var(--text-muted);
    max-width: 32rem;
    margin: 0 0 2rem;
  }

  .hero-split__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-split__btn {
    font-family: 'Nunito', system-ui, sans-serif;
    padding: 0.9375rem 2rem;
    border-radius: 999px;
    font-weight: 700;
    font-size: 1rem;
    display: inline-block;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
  }

  .hero-split__btn--primary {
    background: var(--accent);
    color: #1C1A18;
    box-shadow: var(--shadow-lg);
  }

  .hero-split__btn--secondary {
    background: var(--surface);
    color: var(--text);
    border: 2px solid var(--border);
  }

  @media (hover: hover) {
    .hero-split__btn:hover {
      transform: translateY(-3px) scale(1.05);
      text-decoration: none;
    }
  }

  .hero-split__proof {
    background: var(--surface);
    padding: 2.5rem 2rem;
  }

  .hero-split__proof-heading {
    font-family: 'Nunito', system-ui, sans-serif;
    color: var(--text-muted);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 1.5rem;
  }

  .hero-split__stats {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .hero-split__stat {
    border-top: 1px solid var(--border);
    padding-top: 1.25rem;
  }

  .hero-split__stat:first-child {
    border-top: none;
    padding-top: 0;
  }

  .hero-split__stat-value {
    font-family: 'Nunito', system-ui, sans-serif;
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--primary);
    margin: 0 0 0.25rem;
  }

  .hero-split__stat-label {
    font-family: 'Lora', Georgia, serif;
    color: var(--text-muted);
    font-size: 0.8125rem;
    margin: 0;
  }

  @media (max-width: 860px) {
    .hero-split__inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  /* ---------- editorialLeft ---------- */
  .hero-editorial {
    background: var(--bg);
    min-height: var(--hero-min-height);
    display: flex;
    align-items: center;
    padding: calc(var(--nav-height) + 3rem) 1.5rem 4rem;
  }

  .hero-editorial__inner {
    max-width: var(--container-max);
    margin: 0 auto;
    width: 100%;
    max-width: 46rem;
  }

  .hero-editorial__tagline {
    display: inline-flex;
    color: var(--primary);
    font-weight: 700;
    font-size: 0.9375rem;
    letter-spacing: 0.06em;
    margin: 0 0 1.25rem;
    font-family: 'Nunito', system-ui, sans-serif;
  }

  .hero-editorial__title {
    font-size: calc(clamp(2.75rem, 7vw, 5rem) * var(--heading-scale));
    font-weight: 800;
    color: var(--text);
    line-height: 1;
    letter-spacing: -0.01em;
    margin: 0 0 1.5rem;
  }

  .hero-editorial__subtitle {
    font-family: 'Lora', Georgia, serif;
    font-size: 1.25rem;
    color: var(--text-muted);
    max-width: 32rem;
    margin: 0 0 2.5rem;
  }

  .hero-editorial__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-editorial__btn {
    font-family: 'Nunito', system-ui, sans-serif;
    padding: 0.9375rem 2.25rem;
    border-radius: 999px;
    font-weight: 700;
    font-size: 1rem;
    display: inline-block;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
  }

  .hero-editorial__btn--primary {
    background: var(--accent);
    color: #1C1A18;
    box-shadow: var(--shadow-lg);
  }

  .hero-editorial__btn--secondary {
    background: transparent;
    color: var(--text);
    border: 2px solid var(--border);
  }

  @media (hover: hover) {
    .hero-editorial__btn:hover {
      transform: translateY(-3px) scale(1.05);
      text-decoration: none;
    }
  }
</style>

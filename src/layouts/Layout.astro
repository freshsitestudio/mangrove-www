---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description: descriptionProp } = Astro.props;

// build.env is sourced by npm scripts into process.env (not Vite PUBLIC_*).
// Empty strings are treated as missing so blank build.env values don't wipe fallbacks.
const envOr = (key: string, fallback: string) => {
  const raw = process.env[key];
  if (raw == null) return fallback;
  const trimmed = raw.trim();
  return trimmed.length > 0 ? trimmed : fallback;
};

const description =
  descriptionProp ??
  envOr("SITE_TAGLINE", "Friendly and community-feel — the kind of site that makes people want to walk in.");
const siteName = envOr("SITE_NAME", "Local Favourite");
const siteUrl = envOr("SITE_URL", "");
const navCtaText = envOr("NAV_CTA_TEXT", "Visit us");
const navCtaHref = envOr("NAV_CTA_HREF", "/contact");
const fontUrl = envOr(
  "SITE_GOOGLE_FONTS",
  "https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800&family=Lora:wght@400;500;600&display=swap"
);

// Customer logo: auto-detect public/logo.{svg,png,jpg}, else SITE_LOGO, else placeholder.
const logoModules = import.meta.glob("/public/logo.{svg,png,jpg}", { eager: true });
const logoKeys = Object.keys(logoModules);
const autoLogoSrc = logoKeys.length > 0 ? logoKeys[0].replace(/^\/public/, "") : null;
const siteLogo = autoLogoSrc ?? envOr("SITE_LOGO", "/placeholder-logo.svg");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {siteUrl && <link rel="canonical" href={siteUrl} />}
    <title>{title} | {siteName}</title>

    <!-- Google Fonts CDN — Nunito (headings) + Lora (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href={fontUrl} rel="stylesheet" />
  </head>
  <body>
    <!-- Navigation: solid warm bar, friendly (Layout DNA) -->
    <nav class="site-nav" aria-label="Main navigation">
      <div class="site-nav__inner">
        <a href="/" class="site-nav__brand">
          <img src={siteLogo} alt={siteName} class="site-nav__logo" />
          <span class="site-nav__brand-text">{siteName}</span>
        </a>

        <ul id="nav-links" class="site-nav__links">
          <li><a href="/" class="site-nav__link">Home</a></li>
          <li><a href="/about" class="site-nav__link">About</a></li>
          <li><a href="/services" class="site-nav__link">Services</a></li>
          <li><a href="/contact" class="site-nav__link">Contact</a></li>
          <li><a href={navCtaHref} class="site-nav__cta">{navCtaText}</a></li>
        </ul>

        <button
          id="nav-toggle"
          class="site-nav__toggle"
          aria-controls="nav-links"
          aria-expanded="false"
          aria-label="Toggle navigation menu"
        >
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <line x1="3" y1="6" x2="21" y2="6" />
            <line x1="3" y1="12" x2="21" y2="12" />
            <line x1="3" y1="18" x2="21" y2="18" />
          </svg>
        </button>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <!-- Footer: community-feel warm multi-column (Layout DNA) -->
    <footer class="site-footer">
      <div class="site-footer__inner">
        <div>
          <p class="site-footer__brand">
            <img src={siteLogo} alt="" class="site-footer__logo" />
            {siteName}
          </p>
          <p class="site-footer__tagline">{description}</p>
        </div>
        <div>
          <p class="site-footer__heading">Explore</p>
          <ul class="site-footer__links">
            <li><a href="/about">About</a></li>
            <li><a href="/services">Services</a></li>
          </ul>
        </div>
        <div>
          <p class="site-footer__heading">Find us</p>
          <ul class="site-footer__links site-footer__hours">
            <li><span>Mon–Fri</span><span>7:00–17:00</span></li>
            <li><span>Sat–Sun</span><span>8:00–15:00</span></li>
          </ul>
        </div>
        <div>
          <p class="site-footer__heading">Say hello</p>
          <ul class="site-footer__links">
            <li><a href="/contact">Contact</a></li>
            <li><a href={navCtaHref}>{navCtaText}</a></li>
          </ul>
        </div>
      </div>
      <p class="site-footer__bottom">
        &copy; {new Date().getFullYear()} {siteName}. Made with love for the neighbourhood.
      </p>
    </footer>

    <!-- Mobile nav + motion reveal (Layout DNA: bouncy hover, subtle reveal on scroll) -->
    <script is:inline>
      (function () {
        const toggle = document.getElementById("nav-toggle");
        const links = document.getElementById("nav-links");
        if (toggle && links) {
          toggle.addEventListener("click", function () {
            const expanded = toggle.getAttribute("aria-expanded") === "true";
            const next = !expanded;
            toggle.setAttribute("aria-expanded", String(next));
            links.classList.toggle("is-open", next);
          });
        }

        function handleResize() {
          if (!toggle || !links) return;
          if (window.innerWidth >= 768) {
            links.classList.remove("is-open");
            toggle.setAttribute("aria-expanded", "false");
          }
        }
        window.addEventListener("resize", handleResize);

        var reduceMotion =
          window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        if (reduceMotion || !window.IntersectionObserver) return;

        var revealEls = document.querySelectorAll("[data-reveal]");
        if (!revealEls.length) return;

        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-revealed");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.15, rootMargin: "0px 0px -40px 0px" }
        );
        revealEls.forEach(function (el) {
          observer.observe(el);
        });
      })();
    </script>
  </body>
</html>

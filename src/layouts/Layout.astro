---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description: descriptionProp } = Astro.props;

// build.env is sourced by npm scripts into process.env (not Vite PUBLIC_*).
// Empty strings are treated as missing so blank build.env values don't wipe fallbacks.
const envOr = (key: string, fallback: string) => {
  const raw = process.env[key];
  if (raw == null) return fallback;
  const trimmed = raw.trim();
  return trimmed.length > 0 ? trimmed : fallback;
};

const description =
  descriptionProp ??
  envOr("SITE_TAGLINE", "Friendly and community-feel — the kind of site that makes people want to walk in.");
const siteName = envOr("SITE_NAME", "Local Favourite");
const siteUrl = envOr("SITE_URL", "");
const navCtaText = envOr("NAV_CTA_TEXT", "Visit us");
const navCtaHref = envOr("NAV_CTA_HREF", "/contact");
import { existsSync } from "node:fs";
import { fileURLToPath } from "node:url";

const hasLogoSvg = existsSync(fileURLToPath(new URL("../../public/logo.svg", import.meta.url)));
const hasLogoPng = existsSync(fileURLToPath(new URL("../../public/logo.png", import.meta.url)));
const logoSrc = hasLogoSvg ? "/logo.svg" : (hasLogoPng ? "/logo.png" : null);


---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {siteUrl && <link rel="canonical" href={siteUrl} />}
    <title>{title} | {siteName}</title>

    <!-- Google Fonts CDN — Nunito (headings) + Lora (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800&family=Lora:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- Navigation -->
    <nav
      style="height: var(--nav-height); background: var(--bg); border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 50;"
      aria-label="Main navigation"
    >
      <div
        style="max-width: 72rem; margin: 0 auto; padding: 0 1.5rem; height: 100%; display: flex; align-items: center; justify-content: space-between;"
      >
        <a
          href="/"
          style="display: inline-flex; align-items: center; gap: 0.625rem; color: var(--text); text-decoration: none;"
        >
          {logoSrc && <img src={logoSrc} alt={`${siteName} logo`} style="height: 1.875rem; width: auto; display: block;" />}
          <span style="white-space: nowrap;">{siteName}</span>
        </a>

        <!-- Desktop nav links -->
        <ul
          id="nav-links"
          style="display: flex; gap: 2rem; list-style: none; margin: 0; padding: 0; align-items: center;"
        >
          <li><a href="/" style="color: var(--text-muted); font-weight: 500; font-family: 'Nunito', system-ui, sans-serif;">Home</a></li>
          <li><a href="/about" style="color: var(--text-muted); font-weight: 500; font-family: 'Nunito', system-ui, sans-serif;">About</a></li>
          <li><a href="/services" style="color: var(--text-muted); font-weight: 500; font-family: 'Nunito', system-ui, sans-serif;">Services</a></li>
          <li><a href="/contact" style="color: var(--text-muted); font-weight: 500; font-family: 'Nunito', system-ui, sans-serif;">Contact</a></li>
          <li>
            <a
              href={navCtaHref}
              style="background: var(--accent); color: #1C1A18; padding: 0.5rem 1.25rem; border-radius: var(--radius); font-weight: 600; font-family: 'Nunito', system-ui, sans-serif;"
            >
              {navCtaText}
            </a>
          </li>
        </ul>

        <!-- Mobile hamburger -->
        <button
          id="nav-toggle"
          aria-controls="nav-links"
          aria-expanded="false"
          aria-label="Toggle navigation menu"
          style="display: none; background: none; border: none; cursor: pointer; padding: 0.25rem;"
        >
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <line x1="3" y1="6" x2="21" y2="6" />
            <line x1="3" y1="12" x2="21" y2="12" />
            <line x1="3" y1="18" x2="21" y2="18" />
          </svg>
        </button>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer
      style="background: var(--bg-dark); color: #fff; padding: 2rem 1.5rem; margin-top: 4rem; text-align: center;"
    >
      <p style="opacity: 0.7; font-size: 0.875rem; margin: 0; font-family: 'Nunito', system-ui, sans-serif;">
        &copy; {new Date().getFullYear()} {siteName}. All rights reserved.
      </p>
    </footer>

    <!-- Mobile nav -->
    <script is:inline>
      (function () {
        const toggle = document.getElementById("nav-toggle");
        const links = document.getElementById("nav-links");
        if (toggle && links) {
          toggle.addEventListener("click", function () {
            const expanded = toggle.getAttribute("aria-expanded") === "true";
            const next = !expanded;
            toggle.setAttribute("aria-expanded", String(next));
            links.style.display = next ? "flex" : "none";
          });
        }

        function handleResize() {
          if (!toggle || !links) return;
          if (window.innerWidth < 768) {
            toggle.style.display = "block";
            links.style.display = "none";
            links.style.flexDirection = "column";
            links.style.position = "absolute";
            links.style.top = "var(--nav-height)";
            links.style.left = "0";
            links.style.right = "0";
            links.style.background = "var(--bg)";
            links.style.padding = "1rem 1.5rem";
            links.style.borderBottom = "1px solid var(--border)";
            toggle.setAttribute("aria-expanded", "false");
          } else {
            toggle.style.display = "none";
            toggle.setAttribute("aria-expanded", "false");
            links.style.display = "flex";
            links.style.flexDirection = "";
            links.style.position = "";
            links.style.top = "";
            links.style.left = "";
            links.style.right = "";
            links.style.background = "";
            links.style.padding = "";
            links.style.borderBottom = "";
          }
        }
        handleResize();
        window.addEventListener("resize", handleResize);
      })();
    </script>
  </body>
</html>

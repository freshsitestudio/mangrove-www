# build.env — public site configuration (committed; no secrets)
# Sourced by `npm run build` and `npm run dev` into the shell environment (process.env).
# Layout.astro reads SITE_* / NAV_* from process.env.
# Fonts are loaded via CDN in Layout.astro — do NOT add font settings here.

# --- Site identity ---
SITE_NAME="Local Favourite"
SITE_TAGLINE="Friendly and community-feel — the kind of site that makes people want to walk in."
SITE_URL="https://example.com"

# --- Navigation ---
NAV_CTA_TEXT="Visit us"
NAV_CTA_HREF="/contact"

---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Page Not Found — Mangrove">
  <section style="min-height: 60vh; display: flex; align-items: center; justify-content: center; text-align: center; padding: 4rem 2rem;">
    <div>
      <p style="font-size: 4rem; margin: 0; font-weight: 800; color: var(--border);">404</p>
      <h1 style="font-size: 1.75rem; margin: 1rem 0;">Page not found</h1>
      <p style="color: var(--text-muted); margin-bottom: 2rem;">The page you're looking for doesn't exist.</p>
      <a href="/" class="btn-primary">Back to home →</a>
    </div>
  </section>
</Layout>
